# Backend API Configuration
NEXT_PUBLIC_API_URL=http://backend:8000

# Chat UI Configuration
# For local development, use: http://localhost:3001
# For Docker/Kubernetes, use: http://chat-ui:3001
NEXT_PUBLIC_CHAT_UI_URL=http://localhost:3001

# Application Configuration
NEXT_PUBLIC_APP_NAME=E-commerce Platform
NEXT_PUBLIC_APP_VERSION=1.0.0

# Feature Flags
NEXT_PUBLIC_ENABLE_SEARCH=true
NEXT_PUBLIC_ENABLE_USER_MANAGEMENT=true