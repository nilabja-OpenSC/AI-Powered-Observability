# AI-Powered Observability Platform - Environment Variables Template
# Copy this file to .env and fill in your actual values

# =============================================================================
# LLM Configuration
# =============================================================================

# OpenAI Configuration (Primary)
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_MODEL=gpt-4
OPENAI_TEMPERATURE=0.7
OPENAI_MAX_TOKENS=2000

# Groq Configuration (Alternative)
GROQ_API_KEY=gsk_your-groq-api-key-here
GROQ_MODEL=llama-3.1-70b-versatile
GROQ_TEMPERATURE=0.7
GROQ_MAX_TOKENS=2000

# LLM Provider Selection (openai or groq)
LLM_PROVIDER=openai

# =============================================================================
# Slack Integration
# =============================================================================

SLACK_BOT_TOKEN=xoxb-your-slack-bot-token-here
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL
SLACK_SIGNING_SECRET=your-slack-signing-secret-here
SLACK_CHANNEL=#observability-alerts

# =============================================================================
# Confluence Integration (Optional)
# =============================================================================

CONFLUENCE_URL=https://your-company.atlassian.net
CONFLUENCE_USERNAME=your-email@company.com
CONFLUENCE_API_TOKEN=your-confluence-api-token-here
CONFLUENCE_SPACE=OBSERVABILITY

# =============================================================================
# Database Configuration
# =============================================================================

DATABASE_URL=postgresql://postgres:password@postgresql:5432/ecommerce
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10

# =============================================================================
# Kubernetes Configuration
# =============================================================================

KUBERNETES_NAMESPACE=nilabja-haldar-dev
KUBECONFIG=/path/to/kubeconfig

# =============================================================================
# Observability Stack URLs
# =============================================================================

PROMETHEUS_URL=http://prometheus:9090
GRAFANA_URL=http://grafana:3000
LOKI_URL=http://loki:3100
THANOS_URL=http://thanos-query:9090
ALERTMANAGER_URL=http://alertmanager:9093

# Grafana Credentials
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin

# =============================================================================
# AI Agent Configuration
# =============================================================================

# Supervisor Agent
SUPERVISOR_AGENT_URL=http://supervisor-agent:8080
SUPERVISOR_AGENT_PORT=8080

# Observability Agent
OBSERVABILITY_AGENT_URL=http://observability-agent:8081
OBSERVABILITY_AGENT_PORT=8081

# Pod Recovery Agent
POD_RECOVERY_AGENT_URL=http://pod-recovery-agent:8082
POD_RECOVERY_AGENT_PORT=8082

# Backup/Restore Agent
BACKUP_RESTORE_AGENT_URL=http://backup-restore-agent:8083
BACKUP_RESTORE_AGENT_PORT=8083

# =============================================================================
# Vector Store Configuration
# =============================================================================

CHROMA_PERSIST_DIRECTORY=./chroma_data
CHROMA_COLLECTION_NAME=agent_memory

# =============================================================================
# Approval Workflow Configuration
# =============================================================================

APPROVAL_TIMEOUT_SECONDS=300
APPROVAL_DEFAULT_ACTION=DENY

# =============================================================================
# E-commerce Application
# =============================================================================

# Backend
BACKEND_URL=http://backend:8000
BACKEND_PORT=8000
CORS_ORIGINS=["http://frontend:3000","http://localhost:3000"]

# Frontend
FRONTEND_URL=http://frontend:3000
FRONTEND_PORT=3000
NEXT_PUBLIC_API_URL=http://backend:8000

# Chat UI
CHAT_UI_URL=http://chat-ui:5173
CHAT_UI_PORT=5173
VITE_SUPERVISOR_URL=http://supervisor-agent:8080
VITE_WS_URL=ws://supervisor-agent:8080/ws

# =============================================================================
# Backup/Restore Configuration
# =============================================================================

# Velero
VELERO_NAMESPACE=nilabja-haldar-dev
VELERO_BACKUP_LOCATION=default
VELERO_SNAPSHOT_LOCATION=default

# S3 Configuration (for Velero/Thanos)
AWS_ACCESS_KEY_ID=your-aws-access-key-id
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key
AWS_REGION=us-east-1
S3_BUCKET_NAME=your-backup-bucket-name

# =============================================================================
# Logging Configuration
# =============================================================================

LOG_LEVEL=INFO
LOG_FORMAT=json
LOG_FILE=/var/log/app.log

# =============================================================================
# Security Configuration
# =============================================================================

SECRET_KEY=your-secret-key-for-jwt-signing
JWT_ALGORITHM=HS256
JWT_EXPIRATION_MINUTES=60

# =============================================================================
# Feature Flags
# =============================================================================

ENABLE_THANOS=true
ENABLE_VELERO=true
ENABLE_ARGO_WORKFLOWS=true
ENABLE_CONFLUENCE_DOCS=false

# =============================================================================
# Development/Testing
# =============================================================================

ENVIRONMENT=development
DEBUG=false
TESTING=false

# =============================================================================
# Monitoring & Metrics
# =============================================================================

METRICS_ENABLED=true
METRICS_PORT=9090
HEALTH_CHECK_INTERVAL_SECONDS=30

# =============================================================================
# Rate Limiting
# =============================================================================

RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS_PER_MINUTE=100

# =============================================================================
# Notes
# =============================================================================
# 
# 1. Never commit this file with actual secrets to version control
# 2. Use Kubernetes Secrets for production deployments
# 3. Rotate credentials regularly
# 4. Use different credentials for dev/staging/production
# 5. Ensure KUBERNETES_NAMESPACE is always set to nilabja-haldar-dev
#