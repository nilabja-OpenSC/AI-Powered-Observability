{
  "@context": {
    "@vocab": "http://example.org/observability/requirements#",
    "rdf": "http://www.w3.org/1999/02/22-rdf-syntax-ns#",
    "rdfs": "http://www.w3.org/2000/01/rdf-schema#",
    "owl": "http://www.w3.org/2002/07/owl#",
    "xsd": "http://www.w3.org/2001/XMLSchema#",
    "dcterms": "http://purl.org/dc/terms/",
    "skos": "http://www.w3.org/2004/02/skos/core#"
  },
  "@graph": [
    {
      "@id": "http://example.org/observability/requirements",
      "@type": "owl:Ontology",
      "dcterms:title": "Project Requirements Ontology",
      "dcterms:description": "Ontology for modeling software requirements, architectural decisions, stakeholders, goals, use cases, and test cases with relationships like dependencies, conflicts, and verification",
      "dcterms:created": "2026-05-10",
      "dcterms:creator": "AI-Powered Observability Platform Team",
      "owl:versionInfo": "1.0.0"
    },
    {
      "@id": "Requirement",
      "@type": "owl:Class",
      "rdfs:label": "Requirement",
      "rdfs:comment": "Base class for all types of requirements in the system",
      "skos:definition": "A documented need or expectation that the system must satisfy"
    },
    {
      "@id": "FunctionalRequirement",
      "@type": "owl:Class",
      "rdfs:subClassOf": "Requirement",
      "rdfs:label": "Functional Requirement",
      "rdfs:comment": "Requirement that specifies a function or behavior the system must perform",
      "skos:example": "FR-001: AI agents must detect anomalies in real-time"
    },
    {
      "@id": "NonFunctionalRequirement",
      "@type": "owl:Class",
      "rdfs:subClassOf": "Requirement",
      "rdfs:label": "Non-Functional Requirement",
      "rdfs:comment": "Requirement that specifies quality attributes or constraints",
      "skos:example": "NFR-001: All operations must be namespace-scoped"
    },
    {
      "@id": "SecurityRequirement",
      "@type": "owl:Class",
      "rdfs:subClassOf": "NonFunctionalRequirement",
      "rdfs:label": "Security Requirement",
      "rdfs:comment": "Requirement related to system security, access control, or data protection",
      "skos:example": "SEC-001: Human approval required for all corrective actions"
    },
    {
      "@id": "PerformanceRequirement",
      "@type": "owl:Class",
      "rdfs:subClassOf": "NonFunctionalRequirement",
      "rdfs:label": "Performance Requirement",
      "rdfs:comment": "Requirement specifying performance metrics or constraints",
      "skos:example": "PERF-001: Anomaly detection within 30 seconds"
    },
    {
      "@id": "ArchitecturalDecision",
      "@type": "owl:Class",
      "rdfs:label": "Architectural Decision",
      "rdfs:comment": "A significant design choice that affects the system architecture",
      "skos:definition": "A decision that shapes the structure, behavior, or quality attributes of the system"
    },
    {
      "@id": "Stakeholder",
      "@type": "owl:Class",
      "rdfs:label": "Stakeholder",
      "rdfs:comment": "An individual or group with interest in or influence over the system",
      "skos:example": "Platform Engineers, DevOps Teams, Security Teams"
    },
    {
      "@id": "Goal",
      "@type": "owl:Class",
      "rdfs:label": "Goal",
      "rdfs:comment": "A high-level objective the system aims to achieve",
      "skos:definition": "A desired outcome or state that drives requirements and design decisions"
    },
    {
      "@id": "UseCase",
      "@type": "owl:Class",
      "rdfs:label": "Use Case",
      "rdfs:comment": "A specific scenario describing how actors interact with the system",
      "skos:definition": "A sequence of actions that demonstrates system functionality"
    },
    {
      "@id": "TestCase",
      "@type": "owl:Class",
      "rdfs:label": "Test Case",
      "rdfs:comment": "A set of conditions and steps to verify a requirement",
      "skos:definition": "A specification of test inputs, execution conditions, and expected results"
    },
    {
      "@id": "RequirementStatus",
      "@type": "owl:Class",
      "rdfs:label": "Requirement Status",
      "rdfs:comment": "The current state of a requirement in its lifecycle"
    },
    {
      "@id": "Proposed",
      "@type": ["owl:NamedIndividual", "RequirementStatus"],
      "rdfs:label": "Proposed",
      "rdfs:comment": "Requirement has been proposed but not yet approved"
    },
    {
      "@id": "Approved",
      "@type": ["owl:NamedIndividual", "RequirementStatus"],
      "rdfs:label": "Approved",
      "rdfs:comment": "Requirement has been reviewed and approved for implementation"
    },
    {
      "@id": "Implemented",
      "@type": ["owl:NamedIndividual", "RequirementStatus"],
      "rdfs:label": "Implemented",
      "rdfs:comment": "Requirement has been implemented in code"
    },
    {
      "@id": "Verified",
      "@type": ["owl:NamedIndividual", "RequirementStatus"],
      "rdfs:label": "Verified",
      "rdfs:comment": "Requirement has been tested and verified"
    },
    {
      "@id": "Rejected",
      "@type": ["owl:NamedIndividual", "RequirementStatus"],
      "rdfs:label": "Rejected",
      "rdfs:comment": "Requirement has been rejected and will not be implemented"
    },
    {
      "@id": "requirementId",
      "@type": "owl:DatatypeProperty",
      "rdfs:label": "requirement ID",
      "rdfs:domain": "Requirement",
      "rdfs:range": "xsd:string",
      "rdfs:comment": "Unique identifier for the requirement (e.g., FR-001, NFR-001)"
    },
    {
      "@id": "requirementTitle",
      "@type": "owl:DatatypeProperty",
      "rdfs:label": "requirement title",
      "rdfs:domain": "Requirement",
      "rdfs:range": "xsd:string",
      "rdfs:comment": "Short descriptive title of the requirement"
    },
    {
      "@id": "requirementDescription",
      "@type": "owl:DatatypeProperty",
      "rdfs:label": "requirement description",
      "rdfs:domain": "Requirement",
      "rdfs:range": "xsd:string",
      "rdfs:comment": "Detailed description of what the requirement specifies"
    },
    {
      "@id": "priority",
      "@type": "owl:DatatypeProperty",
      "rdfs:label": "priority",
      "rdfs:domain": "Requirement",
      "rdfs:range": "xsd:string",
      "rdfs:comment": "Priority level: Critical, High, Medium, Low"
    },
    {
      "@id": "status",
      "@type": "owl:ObjectProperty",
      "rdfs:label": "status",
      "rdfs:domain": "Requirement",
      "rdfs:range": "RequirementStatus",
      "rdfs:comment": "Current status of the requirement"
    },
    {
      "@id": "rationale",
      "@type": "owl:DatatypeProperty",
      "rdfs:label": "rationale",
      "rdfs:domain": ["Requirement", "ArchitecturalDecision"],
      "rdfs:range": "xsd:string",
      "rdfs:comment": "Explanation of why this requirement or decision is necessary"
    },
    {
      "@id": "acceptanceCriteria",
      "@type": "owl:DatatypeProperty",
      "rdfs:label": "acceptance criteria",
      "rdfs:domain": "Requirement",
      "rdfs:range": "xsd:string",
      "rdfs:comment": "Conditions that must be met for the requirement to be considered satisfied"
    },
    {
      "@id": "dependsOn",
      "@type": "owl:ObjectProperty",
      "rdfs:label": "depends on",
      "rdfs:domain": "Requirement",
      "rdfs:range": "Requirement",
      "rdfs:comment": "Indicates that one requirement depends on another being satisfied first",
      "owl:propertyChainAxiom": {
        "@list": ["dependsOn", "dependsOn"]
      }
    },
    {
      "@id": "conflictsWith",
      "@type": "owl:ObjectProperty",
      "rdfs:label": "conflicts with",
      "rdfs:domain": "Requirement",
      "rdfs:range": "Requirement",
      "rdfs:comment": "Indicates that two requirements are mutually exclusive or contradictory",
      "rdf:type": "owl:SymmetricProperty"
    },
    {
      "@id": "verifiedBy",
      "@type": "owl:ObjectProperty",
      "rdfs:label": "verified by",
      "rdfs:domain": "Requirement",
      "rdfs:range": "TestCase",
      "rdfs:comment": "Links a requirement to test cases that verify its implementation"
    },
    {
      "@id": "satisfies",
      "@type": "owl:ObjectProperty",
      "rdfs:label": "satisfies",
      "rdfs:domain": "Requirement",
      "rdfs:range": "Goal",
      "rdfs:comment": "Indicates that a requirement contributes to achieving a goal"
    },
    {
      "@id": "implementedBy",
      "@type": "owl:ObjectProperty",
      "rdfs:label": "implemented by",
      "rdfs:domain": "Requirement",
      "rdfs:range": "owl:Thing",
      "rdfs:comment": "Links a requirement to the component or code that implements it"
    },
    {
      "@id": "proposedBy",
      "@type": "owl:ObjectProperty",
      "rdfs:label": "proposed by",
      "rdfs:domain": ["Requirement", "ArchitecturalDecision"],
      "rdfs:range": "Stakeholder",
      "rdfs:comment": "Identifies who proposed the requirement or decision"
    },
    {
      "@id": "influences",
      "@type": "owl:ObjectProperty",
      "rdfs:label": "influences",
      "rdfs:domain": "ArchitecturalDecision",
      "rdfs:range": "Requirement",
      "rdfs:comment": "Indicates that an architectural decision affects a requirement"
    },
    {
      "@id": "relatedTo",
      "@type": "owl:ObjectProperty",
      "rdfs:label": "related to",
      "rdfs:domain": "Requirement",
      "rdfs:range": "Requirement",
      "rdfs:comment": "General relationship between requirements",
      "rdf:type": "owl:SymmetricProperty"
    },
    {
      "@id": "stakeholderName",
      "@type": "owl:DatatypeProperty",
      "rdfs:label": "stakeholder name",
      "rdfs:domain": "Stakeholder",
      "rdfs:range": "xsd:string",
      "rdfs:comment": "Name of the stakeholder or stakeholder group"
    },
    {
      "@id": "stakeholderRole",
      "@type": "owl:DatatypeProperty",
      "rdfs:label": "stakeholder role",
      "rdfs:domain": "Stakeholder",
      "rdfs:range": "xsd:string",
      "rdfs:comment": "Role or responsibility of the stakeholder"
    },
    {
      "@id": "stakeholderInterest",
      "@type": "owl:DatatypeProperty",
      "rdfs:label": "stakeholder interest",
      "rdfs:domain": "Stakeholder",
      "rdfs:range": "xsd:string",
      "rdfs:comment": "What the stakeholder cares about in the system"
    },
    {
      "@id": "goalDescription",
      "@type": "owl:DatatypeProperty",
      "rdfs:label": "goal description",
      "rdfs:domain": "Goal",
      "rdfs:range": "xsd:string",
      "rdfs:comment": "Description of the goal"
    },
    {
      "@id": "goalMetric",
      "@type": "owl:DatatypeProperty",
      "rdfs:label": "goal metric",
      "rdfs:domain": "Goal",
      "rdfs:range": "xsd:string",
      "rdfs:comment": "Measurable metric to determine if goal is achieved"
    },
    {
      "@id": "useCaseTitle",
      "@type": "owl:DatatypeProperty",
      "rdfs:label": "use case title",
      "rdfs:domain": "UseCase",
      "rdfs:range": "xsd:string",
      "rdfs:comment": "Title of the use case"
    },
    {
      "@id": "useCaseDescription",
      "@type": "owl:DatatypeProperty",
      "rdfs:label": "use case description",
      "rdfs:domain": "UseCase",
      "rdfs:range": "xsd:string",
      "rdfs:comment": "Detailed description of the use case scenario"
    },
    {
      "@id": "actor",
      "@type": "owl:ObjectProperty",
      "rdfs:label": "actor",
      "rdfs:domain": "UseCase",
      "rdfs:range": "Stakeholder",
      "rdfs:comment": "The stakeholder who performs the use case"
    },
    {
      "@id": "precondition",
      "@type": "owl:DatatypeProperty",
      "rdfs:label": "precondition",
      "rdfs:domain": ["UseCase", "TestCase"],
      "rdfs:range": "xsd:string",
      "rdfs:comment": "Conditions that must be true before execution"
    },
    {
      "@id": "postcondition",
      "@type": "owl:DatatypeProperty",
      "rdfs:label": "postcondition",
      "rdfs:domain": ["UseCase", "TestCase"],
      "rdfs:range": "xsd:string",
      "rdfs:comment": "Conditions that will be true after successful execution"
    },
    {
      "@id": "testCaseId",
      "@type": "owl:DatatypeProperty",
      "rdfs:label": "test case ID",
      "rdfs:domain": "TestCase",
      "rdfs:range": "xsd:string",
      "rdfs:comment": "Unique identifier for the test case"
    },
    {
      "@id": "testCaseDescription",
      "@type": "owl:DatatypeProperty",
      "rdfs:label": "test case description",
      "rdfs:domain": "TestCase",
      "rdfs:range": "xsd:string",
      "rdfs:comment": "Description of what the test case verifies"
    },
    {
      "@id": "testSteps",
      "@type": "owl:DatatypeProperty",
      "rdfs:label": "test steps",
      "rdfs:domain": "TestCase",
      "rdfs:range": "xsd:string",
      "rdfs:comment": "Step-by-step instructions to execute the test"
    },
    {
      "@id": "expectedResult",
      "@type": "owl:DatatypeProperty",
      "rdfs:label": "expected result",
      "rdfs:domain": "TestCase",
      "rdfs:range": "xsd:string",
      "rdfs:comment": "Expected outcome of the test"
    },
    {
      "@id": "decisionId",
      "@type": "owl:DatatypeProperty",
      "rdfs:label": "decision ID",
      "rdfs:domain": "ArchitecturalDecision",
      "rdfs:range": "xsd:string",
      "rdfs:comment": "Unique identifier for the architectural decision"
    },
    {
      "@id": "decisionTitle",
      "@type": "owl:DatatypeProperty",
      "rdfs:label": "decision title",
      "rdfs:domain": "ArchitecturalDecision",
      "rdfs:range": "xsd:string",
      "rdfs:comment": "Title of the architectural decision"
    },
    {
      "@id": "decisionDescription",
      "@type": "owl:DatatypeProperty",
      "rdfs:label": "decision description",
      "rdfs:domain": "ArchitecturalDecision",
      "rdfs:range": "xsd:string",
      "rdfs:comment": "Detailed description of the decision and its implications"
    },
    {
      "@id": "alternatives",
      "@type": "owl:DatatypeProperty",
      "rdfs:label": "alternatives",
      "rdfs:domain": "ArchitecturalDecision",
      "rdfs:range": "xsd:string",
      "rdfs:comment": "Alternative approaches that were considered"
    },
    {
      "@id": "consequences",
      "@type": "owl:DatatypeProperty",
      "rdfs:label": "consequences",
      "rdfs:domain": "ArchitecturalDecision",
      "rdfs:range": "xsd:string",
      "rdfs:comment": "Impact and implications of the decision"
    },
    {
      "@id": "FR-001",
      "@type": "FunctionalRequirement",
      "requirementId": "FR-001",
      "requirementTitle": "Real-time Anomaly Detection",
      "requirementDescription": "AI agents must detect anomalies in metrics and logs in real-time",
      "priority": "Critical",
      "status": "Implemented",
      "acceptanceCriteria": "Detection within 30 seconds of anomaly occurrence"
    },
    {
      "@id": "FR-002",
      "@type": "FunctionalRequirement",
      "requirementId": "FR-002",
      "requirementTitle": "Human-in-the-Loop Approval",
      "requirementDescription": "All corrective actions require human approval via Slack",
      "priority": "Critical",
      "status": "Implemented",
      "acceptanceCriteria": "Approval request sent to Slack with approve/deny buttons"
    },
    {
      "@id": "NFR-001",
      "@type": "NonFunctionalRequirement",
      "requirementId": "NFR-001",
      "requirementTitle": "Namespace Isolation",
      "requirementDescription": "All operations must be scoped to nilabja-haldar-dev namespace",
      "priority": "Critical",
      "status": "Implemented",
      "acceptanceCriteria": "No cluster-wide RBAC or operations outside namespace"
    },
    {
      "@id": "SEC-001",
      "@type": "SecurityRequirement",
      "requirementId": "SEC-001",
      "requirementTitle": "Approval Timeout Fail-Safe",
      "requirementDescription": "Approval timeout (5 min) must default to DENY",
      "priority": "Critical",
      "status": "Implemented",
      "acceptanceCriteria": "No action executed without explicit approval"
    },
    {
      "@id": "PERF-001",
      "@type": "PerformanceRequirement",
      "requirementId": "PERF-001",
      "requirementTitle": "Query Response Time",
      "requirementDescription": "Prometheus queries must return within 5 seconds",
      "priority": "High",
      "status": "Implemented",
      "acceptanceCriteria": "95th percentile query latency < 5s"
    },
    {
      "@id": "AD-001",
      "@type": "ArchitecturalDecision",
      "decisionId": "AD-001",
      "decisionTitle": "Use LangChain for AI Agent Framework",
      "decisionDescription": "Selected LangChain as the framework for building AI agents",
      "rationale": "Provides tool integration, memory management, and agent orchestration",
      "alternatives": "Custom framework, AutoGPT, Semantic Kernel",
      "consequences": "Dependency on LangChain ecosystem, but faster development"
    },
    {
      "@id": "AD-002",
      "@type": "ArchitecturalDecision",
      "decisionId": "AD-002",
      "decisionTitle": "Namespace-Scoped RBAC Only",
      "decisionDescription": "Use only namespace-scoped Roles, no ClusterRoles",
      "rationale": "Security requirement to prevent cluster-wide access",
      "alternatives": "ClusterRoles with namespace filtering",
      "consequences": "Cannot perform cluster-wide operations, but more secure"
    },
    {
      "@id": "StakeholderPlatformEngineers",
      "@type": "Stakeholder",
      "stakeholderName": "Platform Engineers",
      "stakeholderRole": "System Operators",
      "stakeholderInterest": "Automated incident resolution, reduced manual toil"
    },
    {
      "@id": "StakeholderDevOpsTeams",
      "@type": "Stakeholder",
      "stakeholderName": "DevOps Teams",
      "stakeholderRole": "Application Developers",
      "stakeholderInterest": "Observability insights, deployment automation"
    },
    {
      "@id": "Goal-001",
      "@type": "Goal",
      "goalDescription": "Reduce Mean Time to Resolution (MTTR) for incidents",
      "goalMetric": "MTTR < 10 minutes for common issues"
    },
    {
      "@id": "Goal-002",
      "@type": "Goal",
      "goalDescription": "Achieve 99.9% uptime for critical services",
      "goalMetric": "Monthly uptime percentage"
    },
    {
      "@id": "UC-001",
      "@type": "UseCase",
      "useCaseTitle": "Automated Pod Recovery",
      "useCaseDescription": "Agent detects CrashLoopBackOff and requests approval to restart pod",
      "actor": "StakeholderPlatformEngineers",
      "precondition": "Pod in CrashLoopBackOff state",
      "postcondition": "Pod restarted and running normally"
    },
    {
      "@id": "TC-001",
      "@type": "TestCase",
      "testCaseId": "TC-001",
      "testCaseDescription": "Verify anomaly detection within 30 seconds",
      "testSteps": "1. Inject anomaly 2. Wait for detection 3. Verify alert sent",
      "expectedResult": "Alert received within 30 seconds",
      "verifiedBy": "FR-001"
    }
  ]
}