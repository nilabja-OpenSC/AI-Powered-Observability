{
  "@context": {
    "@vocab": "http://ai-observability.nilabja-haldar.dev/ontology#",
    "rdf": "http://www.w3.org/1999/02/22-rdf-syntax-ns#",
    "rdfs": "http://www.w3.org/2000/01/rdf-schema#",
    "owl": "http://www.w3.org/2002/07/owl#",
    "xsd": "http://www.w3.org/2001/XMLSchema#",
    "dcterms": "http://purl.org/dc/terms/",
    "foaf": "http://xmlns.com/foaf/0.1/",
    "skos": "http://www.w3.org/2004/02/skos/core#"
  },
  "@graph": [
    {
      "@id": "Requirement",
      "@type": "owl:Class",
      "rdfs:label": "Requirement",
      "rdfs:comment": "Base class for all system requirements",
      "rdfs:subClassOf": "owl:Thing"
    },
    {
      "@id": "FunctionalRequirement",
      "@type": "owl:Class",
      "rdfs:label": "Functional Requirement",
      "rdfs:comment": "Requirements that specify system behavior and functionality",
      "rdfs:subClassOf": "Requirement"
    },
    {
      "@id": "NonFunctionalRequirement",
      "@type": "owl:Class",
      "rdfs:label": "Non-Functional Requirement",
      "rdfs:comment": "Requirements that specify system qualities and constraints",
      "rdfs:subClassOf": "Requirement"
    },
    {
      "@id": "SecurityRequirement",
      "@type": "owl:Class",
      "rdfs:label": "Security Requirement",
      "rdfs:comment": "Requirements related to system security and access control",
      "rdfs:subClassOf": "NonFunctionalRequirement"
    },
    {
      "@id": "PerformanceRequirement",
      "@type": "owl:Class",
      "rdfs:label": "Performance Requirement",
      "rdfs:comment": "Requirements related to system performance metrics",
      "rdfs:subClassOf": "NonFunctionalRequirement"
    },
    {
      "@id": "Stakeholder",
      "@type": "owl:Class",
      "rdfs:label": "Stakeholder",
      "rdfs:comment": "Individual or group with interest in the system",
      "rdfs:subClassOf": "foaf:Agent"
    },
    {
      "@id": "Goal",
      "@type": "owl:Class",
      "rdfs:label": "Goal",
      "rdfs:comment": "High-level objective to be achieved by the system",
      "rdfs:subClassOf": "owl:Thing"
    },
    {
      "@id": "UseCase",
      "@type": "owl:Class",
      "rdfs:label": "Use Case",
      "rdfs:comment": "Specific scenario of system usage",
      "rdfs:subClassOf": "owl:Thing"
    },
    {
      "@id": "TestCase",
      "@type": "owl:Class",
      "rdfs:label": "Test Case",
      "rdfs:comment": "Verification procedure for requirements",
      "rdfs:subClassOf": "owl:Thing"
    },
    {
      "@id": "ArchitecturalDecision",
      "@type": "owl:Class",
      "rdfs:label": "Architectural Decision",
      "rdfs:comment": "Key design decision affecting system architecture",
      "rdfs:subClassOf": "owl:Thing"
    },
    {
      "@id": "dependsOn",
      "@type": "owl:ObjectProperty",
      "rdfs:label": "depends on",
      "rdfs:comment": "Indicates dependency between requirements",
      "rdfs:domain": "Requirement",
      "rdfs:range": "Requirement"
    },
    {
      "@id": "conflictsWith",
      "@type": "owl:ObjectProperty",
      "rdfs:label": "conflicts with",
      "rdfs:comment": "Indicates conflict between requirements",
      "rdfs:domain": "Requirement",
      "rdfs:range": "Requirement",
      "owl:propertyDisjointWith": "dependsOn"
    },
    {
      "@id": "verifiedBy",
      "@type": "owl:ObjectProperty",
      "rdfs:label": "verified by",
      "rdfs:comment": "Links requirement to its verification test case",
      "rdfs:domain": "Requirement",
      "rdfs:range": "TestCase"
    },
    {
      "@id": "satisfies",
      "@type": "owl:ObjectProperty",
      "rdfs:label": "satisfies",
      "rdfs:comment": "Links requirement to goal it satisfies",
      "rdfs:domain": "Requirement",
      "rdfs:range": "Goal"
    },
    {
      "@id": "implementedBy",
      "@type": "owl:ObjectProperty",
      "rdfs:label": "implemented by",
      "rdfs:comment": "Links requirement to use case that implements it",
      "rdfs:domain": "Requirement",
      "rdfs:range": "UseCase"
    },
    {
      "@id": "proposedBy",
      "@type": "owl:ObjectProperty",
      "rdfs:label": "proposed by",
      "rdfs:comment": "Links requirement to stakeholder who proposed it",
      "rdfs:domain": "Requirement",
      "rdfs:range": "Stakeholder"
    },
    {
      "@id": "influences",
      "@type": "owl:ObjectProperty",
      "rdfs:label": "influences",
      "rdfs:comment": "Links architectural decision to affected requirements",
      "rdfs:domain": "ArchitecturalDecision",
      "rdfs:range": "Requirement"
    },
    {
      "@id": "requirementId",
      "@type": "owl:DatatypeProperty",
      "rdfs:label": "requirement ID",
      "rdfs:domain": "Requirement",
      "rdfs:range": "xsd:string"
    },
    {
      "@id": "priority",
      "@type": "owl:DatatypeProperty",
      "rdfs:label": "priority",
      "rdfs:domain": "Requirement",
      "rdfs:range": "xsd:string",
      "rdfs:comment": "Priority level: CRITICAL, HIGH, MEDIUM, LOW"
    },
    {
      "@id": "status",
      "@type": "owl:DatatypeProperty",
      "rdfs:label": "status",
      "rdfs:domain": "Requirement",
      "rdfs:range": "xsd:string",
      "rdfs:comment": "Status: PROPOSED, APPROVED, IMPLEMENTED, VERIFIED, REJECTED"
    },
    {
      "@id": "description",
      "@type": "owl:DatatypeProperty",
      "rdfs:label": "description",
      "rdfs:domain": "owl:Thing",
      "rdfs:range": "xsd:string"
    },
    {
      "@id": "rationale",
      "@type": "owl:DatatypeProperty",
      "rdfs:label": "rationale",
      "rdfs:domain": ["Requirement", "ArchitecturalDecision"],
      "rdfs:range": "xsd:string"
    },
    {
      "@id": "acceptanceCriteria",
      "@type": "owl:DatatypeProperty",
      "rdfs:label": "acceptance criteria",
      "rdfs:domain": "Requirement",
      "rdfs:range": "xsd:string"
    },
    {
      "@id": "FR-001",
      "@type": "FunctionalRequirement",
      "requirementId": "FR-001",
      "rdfs:label": "AI Agent Observability Query",
      "description": "System must provide AI agents to query Prometheus, Grafana, and Loki for observability data",
      "priority": "CRITICAL",
      "status": "IMPLEMENTED",
      "rationale": "Core functionality for observability platform",
      "acceptanceCriteria": "Agents can execute PromQL/LogQL queries and return formatted results",
      "satisfies": "GOAL-001",
      "implementedBy": "UC-001",
      "verifiedBy": "TC-001",
      "proposedBy": "STAKEHOLDER-001"
    },
    {
      "@id": "FR-002",
      "@type": "FunctionalRequirement",
      "requirementId": "FR-002",
      "rdfs:label": "Human-in-the-Loop Approval",
      "description": "All corrective actions must require human approval via Slack before execution",
      "priority": "CRITICAL",
      "status": "IMPLEMENTED",
      "rationale": "Safety mechanism to prevent automated actions without oversight",
      "acceptanceCriteria": "Slack notifications sent with approve/deny buttons, 5-minute timeout defaults to DENY",
      "satisfies": "GOAL-002",
      "implementedBy": "UC-002",
      "verifiedBy": "TC-002",
      "dependsOn": "FR-003",
      "proposedBy": "STAKEHOLDER-002"
    },
    {
      "@id": "FR-003",
      "@type": "FunctionalRequirement",
      "requirementId": "FR-003",
      "rdfs:label": "Slack Integration",
      "description": "System must integrate with Slack for notifications and interactive approvals",
      "priority": "CRITICAL",
      "status": "IMPLEMENTED",
      "rationale": "Primary communication channel for human-in-the-loop workflows",
      "acceptanceCriteria": "Slack Block Kit messages with interactive buttons, webhook callbacks handled",
      "satisfies": "GOAL-002",
      "implementedBy": "UC-002",
      "verifiedBy": "TC-003",
      "proposedBy": "STAKEHOLDER-002"
    },
    {
      "@id": "FR-004",
      "@type": "FunctionalRequirement",
      "requirementId": "FR-004",
      "rdfs:label": "Incident Documentation",
      "description": "System must automatically create Confluence pages for approved incidents",
      "priority": "HIGH",
      "status": "IMPLEMENTED",
      "rationale": "Maintain audit trail and knowledge base of incidents",
      "acceptanceCriteria": "Confluence page created with incident details, resolution steps, and outcome",
      "satisfies": "GOAL-003",
      "implementedBy": "UC-003",
      "verifiedBy": "TC-004",
      "dependsOn": "FR-002",
      "proposedBy": "STAKEHOLDER-003"
    },
    {
      "@id": "FR-005",
      "@type": "FunctionalRequirement",
      "requirementId": "FR-005",
      "rdfs:label": "Pod Recovery Agent",
      "description": "Agent must detect and recover pods in CrashLoopBackOff state",
      "priority": "HIGH",
      "status": "IMPLEMENTED",
      "rationale": "Automated recovery of common pod failures",
      "acceptanceCriteria": "Agent detects CrashLoopBackOff, requests approval, restarts pod on approval",
      "satisfies": "GOAL-004",
      "implementedBy": "UC-004",
      "verifiedBy": "TC-005",
      "dependsOn": ["FR-002", "NFR-001"],
      "proposedBy": "STAKEHOLDER-001"
    },
    {
      "@id": "NFR-001",
      "@type": "NonFunctionalRequirement",
      "requirementId": "NFR-001",
      "rdfs:label": "Namespace Isolation",
      "description": "All operations must be scoped to namespace: nilabja-haldar-dev",
      "priority": "CRITICAL",
      "status": "IMPLEMENTED",
      "rationale": "Security constraint to prevent cluster-wide changes",
      "acceptanceCriteria": "All Kubernetes operations include namespace filter, attempts to access other namespaces fail",
      "satisfies": "GOAL-005",
      "verifiedBy": "TC-006",
      "proposedBy": "STAKEHOLDER-002"
    },
    {
      "@id": "SEC-001",
      "@type": "SecurityRequirement",
      "requirementId": "SEC-001",
      "rdfs:label": "Minimal RBAC Permissions",
      "description": "ServiceAccounts must have minimal Role permissions, no cluster-wide RBAC",
      "priority": "CRITICAL",
      "status": "IMPLEMENTED",
      "rationale": "Principle of least privilege for security",
      "acceptanceCriteria": "Roles grant only required permissions within namespace, no ClusterRoles used",
      "satisfies": "GOAL-005",
      "verifiedBy": "TC-007",
      "dependsOn": "NFR-001",
      "proposedBy": "STAKEHOLDER-002"
    },
    {
      "@id": "SEC-002",
      "@type": "SecurityRequirement",
      "requirementId": "SEC-002",
      "rdfs:label": "Fail-Safe Approval Timeout",
      "description": "Approval requests must timeout after 5 minutes and default to DENY",
      "priority": "CRITICAL",
      "status": "IMPLEMENTED",
      "rationale": "Prevent hanging approvals from executing unintended actions",
      "acceptanceCriteria": "Timeout mechanism enforced, denied actions send manual steps to Slack",
      "satisfies": "GOAL-002",
      "verifiedBy": "TC-008",
      "dependsOn": "FR-002",
      "proposedBy": "STAKEHOLDER-002"
    },
    {
      "@id": "PERF-001",
      "@type": "PerformanceRequirement",
      "requirementId": "PERF-001",
      "rdfs:label": "Query Response Time",
      "description": "Prometheus/Loki queries must return results within 5 seconds for recent data",
      "priority": "HIGH",
      "status": "APPROVED",
      "rationale": "Ensure responsive user experience in Chat UI",
      "acceptanceCriteria": "95th percentile query latency < 5 seconds for last 6 hours of data",
      "satisfies": "GOAL-006",
      "verifiedBy": "TC-009",
      "proposedBy": "STAKEHOLDER-001"
    },
    {
      "@id": "PERF-002",
      "@type": "PerformanceRequirement",
      "requirementId": "PERF-002",
      "rdfs:label": "Agent Response Time",
      "description": "AI agents must respond to queries within 10 seconds",
      "priority": "MEDIUM",
      "status": "APPROVED",
      "rationale": "Maintain conversational experience in Chat UI",
      "acceptanceCriteria": "Agent processing time < 10 seconds for 90% of queries",
      "satisfies": "GOAL-006",
      "verifiedBy": "TC-010",
      "proposedBy": "STAKEHOLDER-001"
    },
    {
      "@id": "GOAL-001",
      "@type": "Goal",
      "rdfs:label": "Automated Observability",
      "description": "Enable users to query observability data through natural language AI agents"
    },
    {
      "@id": "GOAL-002",
      "@type": "Goal",
      "rdfs:label": "Safe Automation",
      "description": "Provide automated corrective actions with human oversight and fail-safe mechanisms"
    },
    {
      "@id": "GOAL-003",
      "@type": "Goal",
      "rdfs:label": "Knowledge Management",
      "description": "Maintain comprehensive documentation of incidents and resolutions"
    },
    {
      "@id": "GOAL-004",
      "@type": "Goal",
      "rdfs:label": "Self-Healing Infrastructure",
      "description": "Automatically detect and recover from common infrastructure failures"
    },
    {
      "@id": "GOAL-005",
      "@type": "Goal",
      "rdfs:label": "Security Compliance",
      "description": "Ensure all operations comply with namespace isolation and minimal permissions"
    },
    {
      "@id": "GOAL-006",
      "@type": "Goal",
      "rdfs:label": "Performance Excellence",
      "description": "Deliver responsive user experience with low-latency queries and agent responses"
    },
    {
      "@id": "UC-001",
      "@type": "UseCase",
      "rdfs:label": "Query Prometheus Metrics",
      "description": "User asks 'What is the CPU usage of backend pods?' via Chat UI, agent queries Prometheus and returns formatted results"
    },
    {
      "@id": "UC-002",
      "@type": "UseCase",
      "rdfs:label": "Approve Pod Restart",
      "description": "Agent detects CrashLoopBackOff, sends Slack notification with approve/deny buttons, user approves, pod is restarted"
    },
    {
      "@id": "UC-003",
      "@type": "UseCase",
      "rdfs:label": "Document Incident",
      "description": "After approved pod restart, agent creates Confluence page with incident details and resolution"
    },
    {
      "@id": "UC-004",
      "@type": "UseCase",
      "rdfs:label": "Automated Pod Recovery",
      "description": "Pod enters CrashLoopBackOff, agent detects via Prometheus alert, requests approval, restarts pod on approval"
    },
    {
      "@id": "TC-001",
      "@type": "TestCase",
      "rdfs:label": "Test Prometheus Query Execution",
      "description": "Verify agent can execute PromQL query and return formatted results",
      "acceptanceCriteria": "Query returns valid metrics with correct namespace filter"
    },
    {
      "@id": "TC-002",
      "@type": "TestCase",
      "rdfs:label": "Test Approval Workflow",
      "description": "Verify Slack approval workflow with approve/deny paths",
      "acceptanceCriteria": "Approval executes action, denial sends manual steps, timeout defaults to deny"
    },
    {
      "@id": "TC-003",
      "@type": "TestCase",
      "rdfs:label": "Test Slack Integration",
      "description": "Verify Slack Block Kit messages and interactive buttons",
      "acceptanceCriteria": "Messages formatted correctly, buttons trigger callbacks"
    },
    {
      "@id": "TC-004",
      "@type": "TestCase",
      "rdfs:label": "Test Confluence Documentation",
      "description": "Verify Confluence page creation with incident details",
      "acceptanceCriteria": "Page created with correct format and content"
    },
    {
      "@id": "TC-005",
      "@type": "TestCase",
      "rdfs:label": "Test Pod Recovery",
      "description": "Verify pod restart after approval",
      "acceptanceCriteria": "Pod restarted successfully, status changes from CrashLoopBackOff to Running"
    },
    {
      "@id": "TC-006",
      "@type": "TestCase",
      "rdfs:label": "Test Namespace Isolation",
      "description": "Verify operations are scoped to nilabja-haldar-dev namespace",
      "acceptanceCriteria": "Attempts to access other namespaces fail with error"
    },
    {
      "@id": "TC-007",
      "@type": "TestCase",
      "rdfs:label": "Test RBAC Permissions",
      "description": "Verify ServiceAccounts have minimal required permissions",
      "acceptanceCriteria": "Roles grant only necessary permissions, no cluster-wide access"
    },
    {
      "@id": "TC-008",
      "@type": "TestCase",
      "rdfs:label": "Test Approval Timeout",
      "description": "Verify approval timeout defaults to DENY after 5 minutes",
      "acceptanceCriteria": "Timeout triggers deny action, manual steps sent to Slack"
    },
    {
      "@id": "TC-009",
      "@type": "TestCase",
      "rdfs:label": "Test Query Performance",
      "description": "Verify Prometheus/Loki query response time",
      "acceptanceCriteria": "95th percentile latency < 5 seconds for recent data"
    },
    {
      "@id": "TC-010",
      "@type": "TestCase",
      "rdfs:label": "Test Agent Response Time",
      "description": "Verify AI agent processing time",
      "acceptanceCriteria": "90% of queries processed within 10 seconds"
    },
    {
      "@id": "STAKEHOLDER-001",
      "@type": "Stakeholder",
      "foaf:name": "Platform Engineers",
      "rdfs:label": "Platform Engineers",
      "description": "Primary users who query observability data and manage infrastructure"
    },
    {
      "@id": "STAKEHOLDER-002",
      "@type": "Stakeholder",
      "foaf:name": "Security Team",
      "rdfs:label": "Security Team",
      "description": "Ensures compliance with security policies and namespace isolation"
    },
    {
      "@id": "STAKEHOLDER-003",
      "@type": "Stakeholder",
      "foaf:name": "Operations Team",
      "rdfs:label": "Operations Team",
      "description": "Manages incident response and documentation"
    },
    {
      "@id": "AD-001",
      "@type": "ArchitecturalDecision",
      "rdfs:label": "Use OpenAI + LangChain for AI Agents",
      "description": "Primary tech stack: OpenAI for LLM, LangChain for agent framework, Chroma for vector store",
      "rationale": "Mature ecosystem with extensive tooling and community support",
      "influences": ["FR-001", "FR-005", "PERF-002"]
    },
    {
      "@id": "AD-002",
      "@type": "ArchitecturalDecision",
      "rdfs:label": "Namespace-Scoped Operations Only",
      "description": "All Kubernetes operations restricted to nilabja-haldar-dev namespace",
      "rationale": "Security constraint to prevent cluster-wide changes in shared environment",
      "influences": ["NFR-001", "SEC-001", "FR-005"]
    },
    {
      "@id": "AD-003",
      "@type": "ArchitecturalDecision",
      "rdfs:label": "Slack as Primary Communication Channel",
      "description": "Use Slack for issue notifications, approvals, and incident updates",
      "rationale": "Existing team communication platform with rich interactive capabilities",
      "influences": ["FR-002", "FR-003", "SEC-002"]
    },
    {
      "@id": "AD-004",
      "@type": "ArchitecturalDecision",
      "rdfs:label": "Separate Chat UI and Slack Workflows",
      "description": "Chat UI for queries only, Slack for approvals and notifications",
      "rationale": "Clear separation of concerns: read-only queries vs mutation workflows",
      "influences": ["FR-001", "FR-002"]
    },
    {
      "@id": "AD-005",
      "@type": "ArchitecturalDecision",
      "rdfs:label": "Fail-Safe Approval Mechanism",
      "description": "Default to DENY on timeout or error in approval workflow",
      "rationale": "Safety-first approach to prevent unintended automated actions",
      "influences": ["FR-002", "SEC-002"]
    }
  ]
}