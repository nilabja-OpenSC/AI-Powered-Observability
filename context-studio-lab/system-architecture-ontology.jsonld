{
  "@context": {
    "sao": "http://ai-observability.nilabja-haldar.dev/architecture#",
    "schema": "http://schema.org/",
    "id": "@id",
    "type": "@type",
    "name": "schema:name",
    "description": "schema:description",
    "attributes": "sao:attributes",
    "identityKey": "sao:identityKey",
    "humanRef": "sao:humanRef",
    "invariant": "sao:invariant",
    "hasState": {
      "@id": "sao:hasState",
      "@type": "@id"
    },
    "initialState": {
      "@id": "sao:initialState",
      "@type": "@id"
    },
    "terminalStates": {
      "@id": "sao:terminalStates",
      "@type": "@id"
    },
    "relatesTo": {
      "@id": "sao:relatesTo",
      "@type": "@id"
    },
    "emitsEvent": {
      "@id": "sao:emitsEvent",
      "@type": "@id"
    },
    "from": {
      "@id": "sao:from",
      "@type": "@id"
    },
    "to": {
      "@id": "sao:to",
      "@type": "@id"
    },
    "precondition": "sao:precondition",
    "postcondition": "sao:postcondition",
    "Entity": "sao:Entity",
    "Operation": "sao:Operation",
    "State": "sao:State"
  },
  "@graph": [
    {
      "id": "sao:Component",
      "type": "Entity",
      "name": "Component",
      "description": "A deployable unit of the AI-Powered Observability Platform",
      "identityKey": "componentId: UUID",
      "humanRef": "componentName",
      "attributes": {
        "componentId": "string",
        "componentName": "string",
        "description": "string",
        "technology": "string",
        "port": "integer|null",
        "namespace": "string",
        "componentType": "APPLICATION|INFRASTRUCTURE|DATA_STORE"
      },
      "invariant": [
        "componentName must be unique within namespace",
        "All components must be deployed in nilabja-haldar-dev namespace",
        "Port must be unique if specified"
      ],
      "hasState": [
        "sao:ComponentPending",
        "sao:ComponentDeploying",
        "sao:ComponentRunning",
        "sao:ComponentFailed",
        "sao:ComponentStopped"
      ],
      "initialState": "sao:ComponentPending",
      "terminalStates": [
        "sao:ComponentStopped"
      ],
      "relatesTo": [
        "sao:Component",
        "sao:DataStore",
        "sao:CommunicationChannel"
      ],
      "emitsEvent": [
        "sao:ComponentDeployed",
        "sao:ComponentStarted",
        "sao:ComponentFailed"
      ]
    },
    {
      "id": "sao:ApplicationComponent",
      "type": "Entity",
      "name": "ApplicationComponent",
      "description": "Application-layer component (Backend, Frontend, AI Agents)",
      "identityKey": "componentId: UUID",
      "humanRef": "componentName",
      "attributes": {
        "componentId": "string",
        "componentName": "string",
        "description": "string",
        "technology": "string",
        "port": "integer",
        "replicas": "integer",
        "resourceLimits": "object"
      },
      "invariant": [
        "Must expose at least one communication channel",
        "Must be monitored by Prometheus",
        "Must have health check endpoint"
      ],
      "hasState": [
        "sao:ComponentPending",
        "sao:ComponentDeploying",
        "sao:ComponentRunning",
        "sao:ComponentFailed",
        "sao:ComponentStopped"
      ],
      "initialState": "sao:ComponentPending",
      "terminalStates": [
        "sao:ComponentStopped"
      ],
      "relatesTo": [
        "sao:InfrastructureComponent",
        "sao:DataStore"
      ]
    },
    {
      "id": "sao:InfrastructureComponent",
      "type": "Entity",
      "name": "InfrastructureComponent",
      "description": "Infrastructure-layer component (Prometheus, Loki, Grafana)",
      "identityKey": "componentId: UUID",
      "humanRef": "componentName",
      "attributes": {
        "componentId": "string",
        "componentName": "string",
        "description": "string",
        "technology": "string",
        "port": "integer",
        "retentionPeriod": "string|null",
        "storageSize": "string|null"
      },
      "invariant": [
        "Must be deployed in nilabja-haldar-dev namespace",
        "Must have persistent storage if stateful",
        "Must expose metrics endpoint"
      ],
      "hasState": [
        "sao:ComponentPending",
        "sao:ComponentDeploying",
        "sao:ComponentRunning",
        "sao:ComponentFailed",
        "sao:ComponentStopped"
      ],
      "initialState": "sao:ComponentPending",
      "terminalStates": [
        "sao:ComponentStopped"
      ],
      "relatesTo": [
        "sao:DataStore",
        "sao:ApplicationComponent"
      ]
    },
    {
      "id": "sao:DataStore",
      "type": "Entity",
      "name": "DataStore",
      "description": "Persistent data storage component",
      "identityKey": "dataStoreId: UUID",
      "humanRef": "dataStoreName",
      "attributes": {
        "dataStoreId": "string",
        "dataStoreName": "string",
        "description": "string",
        "technology": "string",
        "storageType": "PERSISTENT_VOLUME|OBJECT_STORAGE|TSDB",
        "capacity": "string",
        "backupEnabled": "boolean"
      },
      "invariant": [
        "dataStoreName must be unique",
        "Must have backup strategy if critical",
        "Must be scoped to nilabja-haldar-dev namespace"
      ],
      "hasState": [
        "sao:DataStoreProvisioning",
        "sao:DataStoreReady",
        "sao:DataStoreFull",
        "sao:DataStoreFailed"
      ],
      "initialState": "sao:DataStoreProvisioning",
      "terminalStates": [
        "sao:DataStoreFailed"
      ],
      "relatesTo": [
        "sao:Component"
      ]
    },
    {
      "id": "sao:CommunicationChannel",
      "type": "Entity",
      "name": "CommunicationChannel",
      "description": "Mechanism for inter-component communication",
      "identityKey": "channelId: UUID",
      "humanRef": "channelName",
      "attributes": {
        "channelId": "string",
        "channelName": "string",
        "protocol": "HTTP|HTTPS|WEBSOCKET|GRPC|PROMQL|LOGQL",
        "format": "JSON|PROTOBUF|QUERY_LANGUAGE",
        "secured": "boolean"
      },
      "invariant": [
        "channelName must be unique",
        "External channels must use HTTPS",
        "Must define clear contract/schema"
      ],
      "relatesTo": [
        "sao:Component"
      ]
    },
    {
      "id": "sao:DependsOn",
      "type": "Operation",
      "name": "DependsOn",
      "description": "Defines dependency between components",
      "from": "sao:Component",
      "to": "sao:Component",
      "precondition": [
        "Both components must exist",
        "No circular dependencies allowed",
        "Dependent component must start after dependency"
      ],
      "postcondition": [
        "Dependency relationship is recorded",
        "Deployment order is enforced",
        "Health checks validate dependency availability"
      ]
    },
    {
      "id": "sao:CommunicatesWith",
      "type": "Operation",
      "name": "CommunicatesWith",
      "description": "Establishes communication between components",
      "from": "sao:Component",
      "to": "sao:Component",
      "precondition": [
        "Both components must be running",
        "Communication channel must be defined",
        "Network policies must allow traffic"
      ],
      "postcondition": [
        "Communication is established",
        "Traffic is monitored and logged",
        "Errors are tracked and alerted"
      ]
    },
    {
      "id": "sao:DeploysTo",
      "type": "Operation",
      "name": "DeploysTo",
      "description": "Deploys component to infrastructure",
      "from": "sao:ApplicationComponent",
      "to": "sao:InfrastructureComponent",
      "precondition": [
        "Infrastructure must be ready",
        "Component must be packaged (container image)",
        "Namespace must exist"
      ],
      "postcondition": [
        "Component is deployed and running",
        "Health checks are passing",
        "Metrics are being collected"
      ]
    },
    {
      "id": "sao:Stores",
      "type": "Operation",
      "name": "Stores",
      "description": "Component stores data in data store",
      "from": "sao:Component",
      "to": "sao:DataStore",
      "precondition": [
        "DataStore must be ready",
        "Component must have credentials",
        "Storage capacity must be available"
      ],
      "postcondition": [
        "Data is persisted",
        "Backups are configured (if enabled)",
        "Storage usage is monitored"
      ]
    },
    {
      "id": "sao:Monitors",
      "type": "Operation",
      "name": "Monitors",
      "description": "Component monitors another component",
      "from": "sao:InfrastructureComponent",
      "to": "sao:Component",
      "precondition": [
        "Monitoring component must be running",
        "Target component must expose metrics",
        "ServiceMonitor must be configured"
      ],
      "postcondition": [
        "Metrics are being collected",
        "Alerts are configured",
        "Dashboards are available"
      ]
    },
    {
      "id": "sao:Exposes",
      "type": "Operation",
      "name": "Exposes",
      "description": "Component exposes communication channel",
      "from": "sao:Component",
      "to": "sao:CommunicationChannel",
      "precondition": [
        "Component must be running",
        "Port must be available",
        "Service must be configured"
      ],
      "postcondition": [
        "Channel is accessible",
        "Traffic is routed correctly",
        "Channel is documented in API specs"
      ]
    },
    {
      "id": "sao:ComponentPending",
      "type": "State",
      "name": "ComponentPending",
      "description": "Component is pending deployment"
    },
    {
      "id": "sao:ComponentDeploying",
      "type": "State",
      "name": "ComponentDeploying",
      "description": "Component is being deployed"
    },
    {
      "id": "sao:ComponentRunning",
      "type": "State",
      "name": "ComponentRunning",
      "description": "Component is running and healthy"
    },
    {
      "id": "sao:ComponentFailed",
      "type": "State",
      "name": "ComponentFailed",
      "description": "Component deployment or runtime failed"
    },
    {
      "id": "sao:ComponentStopped",
      "type": "State",
      "name": "ComponentStopped",
      "description": "Component is stopped"
    },
    {
      "id": "sao:DataStoreProvisioning",
      "type": "State",
      "name": "DataStoreProvisioning",
      "description": "Data store is being provisioned"
    },
    {
      "id": "sao:DataStoreReady",
      "type": "State",
      "name": "DataStoreReady",
      "description": "Data store is ready for use"
    },
    {
      "id": "sao:DataStoreFull",
      "type": "State",
      "name": "DataStoreFull",
      "description": "Data store is at capacity"
    },
    {
      "id": "sao:DataStoreFailed",
      "type": "State",
      "name": "DataStoreFailed",
      "description": "Data store has failed"
    }
  ]
}