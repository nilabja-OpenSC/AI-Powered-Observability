{
  "@context": {
    "awo": "http://ai-observability.nilabja-haldar.dev/workflows#",
    "schema": "http://schema.org/",
    "id": "@id",
    "type": "@type",
    "name": "schema:name",
    "description": "schema:description",
    "attributes": "awo:attributes",
    "identityKey": "awo:identityKey",
    "humanRef": "awo:humanRef",
    "invariant": "awo:invariant",
    "hasState": {
      "@id": "awo:hasState",
      "@type": "@id"
    },
    "initialState": {
      "@id": "awo:initialState",
      "@type": "@id"
    },
    "terminalStates": {
      "@id": "awo:terminalStates",
      "@type": "@id"
    },
    "relatesTo": {
      "@id": "awo:relatesTo",
      "@type": "@id"
    },
    "emitsEvent": {
      "@id": "awo:emitsEvent",
      "@type": "@id"
    },
    "from": {
      "@id": "awo:from",
      "@type": "@id"
    },
    "to": {
      "@id": "awo:to",
      "@type": "@id"
    },
    "precondition": "awo:precondition",
    "postcondition": "awo:postcondition",
    "Entity": "awo:Entity",
    "Operation": "awo:Operation",
    "State": "awo:State"
  },
  "@graph": [
    {
      "id": "awo:Workflow",
      "type": "Entity",
      "name": "Workflow",
      "description": "A sequence of steps executed by AI agents to accomplish a task",
      "identityKey": "workflowId: UUID",
      "humanRef": "workflowName",
      "attributes": {
        "workflowId": "string",
        "workflowName": "string",
        "description": "string",
        "executionMode": "SYNCHRONOUS|ASYNCHRONOUS",
        "approvalRequired": "boolean",
        "approvalTimeout": "integer|null",
        "steps": "array<WorkflowStep>",
        "namespace": "string"
      },
      "invariant": [
        "workflowName must be unique",
        "All operations must be scoped to nilabja-haldar-dev namespace",
        "If approvalRequired is true, approvalTimeout must be set (default: 300 seconds)",
        "Approval timeout defaults to DENY on expiration"
      ],
      "hasState": [
        "awo:WorkflowPending",
        "awo:WorkflowRunning",
        "awo:WorkflowWaitingApproval",
        "awo:WorkflowCompleted",
        "awo:WorkflowFailed",
        "awo:WorkflowCancelled"
      ],
      "initialState": "awo:WorkflowPending",
      "terminalStates": [
        "awo:WorkflowCompleted",
        "awo:WorkflowFailed",
        "awo:WorkflowCancelled"
      ],
      "relatesTo": [
        "awo:WorkflowStep",
        "awo:ApprovalFlow",
        "awo:Agent"
      ],
      "emitsEvent": [
        "awo:WorkflowStarted",
        "awo:WorkflowCompleted",
        "awo:WorkflowFailed",
        "awo:ApprovalRequested"
      ]
    },
    {
      "id": "awo:WorkflowStep",
      "type": "Entity",
      "name": "WorkflowStep",
      "description": "An individual step within a workflow execution",
      "identityKey": "stepId: UUID",
      "humanRef": "stepName",
      "attributes": {
        "stepId": "string",
        "stepName": "string",
        "stepNumber": "integer",
        "action": "string",
        "inputs": "array<string>",
        "outputs": "array<string>",
        "tool": "string|null",
        "condition": "string|null",
        "timeout": "integer|null",
        "defaultAction": "string|null"
      },
      "invariant": [
        "stepNumber must be unique within workflow",
        "Steps must be executed in sequential order",
        "Required inputs must be provided before execution",
        "Tool must exist in ToolRegistry if specified"
      ],
      "hasState": [
        "awo:StepPending",
        "awo:StepRunning",
        "awo:StepCompleted",
        "awo:StepFailed",
        "awo:StepSkipped"
      ],
      "initialState": "awo:StepPending",
      "terminalStates": [
        "awo:StepCompleted",
        "awo:StepFailed",
        "awo:StepSkipped"
      ],
      "relatesTo": [
        "awo:Workflow",
        "awo:Tool",
        "awo:DecisionPoint"
      ]
    },
    {
      "id": "awo:ApprovalFlow",
      "type": "Entity",
      "name": "ApprovalFlow",
      "description": "Human-in-the-loop approval workflow for mutation operations",
      "identityKey": "approvalFlowId: UUID",
      "humanRef": "approvalFlowName",
      "attributes": {
        "approvalFlowId": "string",
        "approvalFlowName": "string",
        "description": "string",
        "approvers": "array<string>",
        "channel": "SLACK|EMAIL",
        "timeout": "integer",
        "defaultAction": "DENY|APPROVE",
        "notificationTemplate": "object"
      },
      "invariant": [
        "timeout must be positive integer (seconds)",
        "defaultAction must be DENY for fail-safe behavior",
        "At least one approver must be specified",
        "Notification must be sent via Slack for real-time approvals"
      ],
      "hasState": [
        "awo:ApprovalPending",
        "awo:ApprovalApproved",
        "awo:ApprovalDenied",
        "awo:ApprovalTimeout"
      ],
      "initialState": "awo:ApprovalPending",
      "terminalStates": [
        "awo:ApprovalApproved",
        "awo:ApprovalDenied",
        "awo:ApprovalTimeout"
      ],
      "relatesTo": [
        "awo:Workflow",
        "awo:WorkflowStep"
      ],
      "emitsEvent": [
        "awo:ApprovalRequested",
        "awo:ApprovalGranted",
        "awo:ApprovalDenied",
        "awo:ApprovalTimedOut"
      ]
    },
    {
      "id": "awo:DecisionPoint",
      "type": "Entity",
      "name": "DecisionPoint",
      "description": "A point in workflow where execution branches based on conditions",
      "identityKey": "decisionPointId: UUID",
      "humanRef": "decisionPointName",
      "attributes": {
        "decisionPointId": "string",
        "decisionPointName": "string",
        "description": "string",
        "conditions": "array<object>",
        "evaluationStrategy": "FIRST_MATCH|ALL_MATCH"
      },
      "invariant": [
        "At least one condition must be defined",
        "Conditions must be mutually exclusive or have default case",
        "Each condition must specify target step or action"
      ],
      "relatesTo": [
        "awo:WorkflowStep"
      ]
    },
    {
      "id": "awo:TriggerWorkflow",
      "type": "Operation",
      "name": "TriggerWorkflow",
      "description": "Initiates a workflow execution",
      "from": "awo:Agent",
      "to": "awo:Workflow",
      "precondition": [
        "Agent must be authorized to trigger workflow",
        "Workflow must be in valid state to start",
        "Required inputs must be provided"
      ],
      "postcondition": [
        "Workflow transitions to RUNNING state",
        "WorkflowStarted event is emitted",
        "First step is queued for execution"
      ]
    },
    {
      "id": "awo:ExecuteStep",
      "type": "Operation",
      "name": "ExecuteStep",
      "description": "Executes a single workflow step",
      "from": "awo:Workflow",
      "to": "awo:WorkflowStep",
      "precondition": [
        "Previous step must be completed (if sequential)",
        "Required inputs must be available",
        "Tool must be available (if specified)"
      ],
      "postcondition": [
        "Step transitions to COMPLETED or FAILED state",
        "Outputs are produced and stored",
        "Next step is triggered (if not terminal)"
      ]
    },
    {
      "id": "awo:RequestApproval",
      "type": "Operation",
      "name": "RequestApproval",
      "description": "Requests human approval for mutation operation",
      "from": "awo:WorkflowStep",
      "to": "awo:ApprovalFlow",
      "precondition": [
        "Workflow step requires approval",
        "Approval flow is configured",
        "Notification channel is available"
      ],
      "postcondition": [
        "Workflow transitions to WAITING_APPROVAL state",
        "Slack notification sent with approve/deny buttons",
        "Approval timeout timer started (default: 5 minutes)",
        "ApprovalRequested event is emitted"
      ]
    },
    {
      "id": "awo:GrantApproval",
      "type": "Operation",
      "name": "GrantApproval",
      "description": "Human approves the requested action",
      "from": "awo:ApprovalFlow",
      "to": "awo:Workflow",
      "precondition": [
        "Approval request is pending",
        "Approver is authorized",
        "Timeout has not expired"
      ],
      "postcondition": [
        "Approval flow transitions to APPROVED state",
        "Workflow resumes execution",
        "Mutation operation is executed",
        "ApprovalGranted event is emitted"
      ]
    },
    {
      "id": "awo:DenyApproval",
      "type": "Operation",
      "name": "DenyApproval",
      "description": "Human denies the requested action",
      "from": "awo:ApprovalFlow",
      "to": "awo:Workflow",
      "precondition": [
        "Approval request is pending",
        "Approver is authorized"
      ],
      "postcondition": [
        "Approval flow transitions to DENIED state",
        "Workflow transitions to CANCELLED state",
        "Manual resolution steps sent to Slack",
        "ApprovalDenied event is emitted"
      ]
    },
    {
      "id": "awo:TimeoutApproval",
      "type": "Operation",
      "name": "TimeoutApproval",
      "description": "Approval request times out (defaults to DENY)",
      "from": "awo:ApprovalFlow",
      "to": "awo:Workflow",
      "precondition": [
        "Approval request is pending",
        "Timeout period has elapsed (default: 300 seconds)"
      ],
      "postcondition": [
        "Approval flow transitions to TIMEOUT state",
        "Workflow transitions to CANCELLED state (fail-safe)",
        "Timeout notification sent to Slack",
        "ApprovalTimedOut event is emitted"
      ]
    },
    {
      "id": "awo:EvaluateDecision",
      "type": "Operation",
      "name": "EvaluateDecision",
      "description": "Evaluates conditions at decision point to determine next step",
      "from": "awo:WorkflowStep",
      "to": "awo:DecisionPoint",
      "precondition": [
        "Decision point is defined",
        "Required variables for evaluation are available"
      ],
      "postcondition": [
        "Matching condition is identified",
        "Workflow branches to appropriate next step",
        "Decision result is logged"
      ]
    },
    {
      "id": "awo:CompleteWorkflow",
      "type": "Operation",
      "name": "CompleteWorkflow",
      "description": "Marks workflow as completed",
      "from": "awo:WorkflowStep",
      "to": "awo:Workflow",
      "precondition": [
        "All required steps are completed",
        "No pending approvals",
        "Terminal step has executed successfully"
      ],
      "postcondition": [
        "Workflow transitions to COMPLETED state",
        "WorkflowCompleted event is emitted",
        "Results are stored and documented",
        "Confluence page created (if configured)"
      ]
    },
    {
      "id": "awo:FailWorkflow",
      "type": "Operation",
      "name": "FailWorkflow",
      "description": "Marks workflow as failed due to error",
      "from": "awo:WorkflowStep",
      "to": "awo:Workflow",
      "precondition": [
        "Step execution encountered error",
        "Error is not recoverable"
      ],
      "postcondition": [
        "Workflow transitions to FAILED state",
        "WorkflowFailed event is emitted",
        "Error details logged and sent to Slack",
        "Rollback actions executed (if defined)"
      ]
    },
    {
      "id": "awo:WorkflowPending",
      "type": "State",
      "name": "WorkflowPending",
      "description": "Workflow is created but not yet started"
    },
    {
      "id": "awo:WorkflowRunning",
      "type": "State",
      "name": "WorkflowRunning",
      "description": "Workflow is actively executing steps"
    },
    {
      "id": "awo:WorkflowWaitingApproval",
      "type": "State",
      "name": "WorkflowWaitingApproval",
      "description": "Workflow is paused waiting for human approval"
    },
    {
      "id": "awo:WorkflowCompleted",
      "type": "State",
      "name": "WorkflowCompleted",
      "description": "Workflow completed successfully"
    },
    {
      "id": "awo:WorkflowFailed",
      "type": "State",
      "name": "WorkflowFailed",
      "description": "Workflow failed with error"
    },
    {
      "id": "awo:WorkflowCancelled",
      "type": "State",
      "name": "WorkflowCancelled",
      "description": "Workflow cancelled by user or timeout"
    },
    {
      "id": "awo:StepPending",
      "type": "State",
      "name": "StepPending",
      "description": "Step is queued for execution"
    },
    {
      "id": "awo:StepRunning",
      "type": "State",
      "name": "StepRunning",
      "description": "Step is currently executing"
    },
    {
      "id": "awo:StepCompleted",
      "type": "State",
      "name": "StepCompleted",
      "description": "Step completed successfully"
    },
    {
      "id": "awo:StepFailed",
      "type": "State",
      "name": "StepFailed",
      "description": "Step failed with error"
    },
    {
      "id": "awo:StepSkipped",
      "type": "State",
      "name": "StepSkipped",
      "description": "Step skipped due to condition"
    },
    {
      "id": "awo:ApprovalPending",
      "type": "State",
      "name": "ApprovalPending",
      "description": "Approval request sent, awaiting human decision"
    },
    {
      "id": "awo:ApprovalApproved",
      "type": "State",
      "name": "ApprovalApproved",
      "description": "Human approved the requested action"
    },
    {
      "id": "awo:ApprovalDenied",
      "type": "State",
      "name": "ApprovalDenied",
      "description": "Human denied the requested action"
    },
    {
      "id": "awo:ApprovalTimeout",
      "type": "State",
      "name": "ApprovalTimeout",
      "description": "Approval request timed out (defaults to DENY)"
    }
  ]
}